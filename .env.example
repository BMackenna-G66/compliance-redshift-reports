# =============================================================
# WatchTower AML — Variables de entorno / secretos
# =============================================================
# Este archivo es solo documentación. Nunca commitear valores reales.
# Los valores reales van como GitHub Secrets (Settings → Secrets → Actions).
# =============================================================

# ---- API Gateway ----
API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# ---- Cognito ----
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=compliance-reports.auth.us-east-1.amazoncognito.com
AWS_REGION=us-east-1

# ---- Gemini AI (análisis AML) ----
# Obtener en: https://aistudio.google.com/app/apikey
# Agregar como GitHub Secret con nombre exacto: GEMINI_KEY
GEMINI_KEY=AIzaSy...

# ---- Desarrollo local ----
# Para correr la app localmente, crear frontend/config.json con estos valores:
# {
#   "apiUrl": "...",
#   "geminiKey": "AIzaSy...",
#   "userPoolId": "...",
#   "clientId": "...",
#   "cognitoDomain": "...",
#   "region": "us-east-1"
# }
# El archivo frontend/config.json está en .gitignore — nunca se sube al repo.
